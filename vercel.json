{
  "rewrites": [
    {
      "source": "/sofascore-api/:path*",
      "destination": "https://www.sofascore.com/api/v1/:path*"
    },
    {
      "source": "/v1/api/:path*",
      "destination": "https://prod-public-api.livescore.com/v1/api/:path*"
    },
    {
      "source": "/en/football/:path*",
      "destination": "https://www.livescore.com/en/football/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}